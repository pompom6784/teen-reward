includes:
  - ./vendor/larastan/larastan/extension.neon
  - ./vendor/phpstan/phpstan/conf/bleedingEdge.neon

parameters:
  level: 5
  paths:
    - app
    - database
    - routes
    - tests
  inferPrivatePropertyTypeFromConstructor: true
  checkMissingVarTagTypehint: false
  checkExplicitMixed: false
